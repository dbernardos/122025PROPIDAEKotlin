<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_metallic"
    tools:context=".MainActivity">

    <!-- 1. CABEÇALHO (Topo) -->
    <!-- Usamos um fundo com gradiente sutil para dar textura -->
    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/header_gradient"
        android:fontFamily="sans-serif-black"
        android:gravity="center"
        android:letterSpacing="0.05"
        android:text="@string/nome_evento"
        android:textColor="@android:color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.15"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2. CORPO (Meio - Texto e Botão) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardBody"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="24dp"
        app:cardBackgroundColor="@color/card_surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toTopOf="@+id/layoutFooter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Ícone decorativo (Engrenagem ou similar) -->
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_engineering"
                android:contentDescription="Icone Engenharia"
                app:tint="@color/accent_orange" />

            <TextView
                android:id="@+id/tvMainText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="Bem-vindo ao futuro da mecânica.\nAcesse as ferramentas, projetos e a comunidade de engenharia agora."
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:lineSpacingMultiplier="1.2" />

            <Button
                android:id="@+id/btnAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:backgroundTint="@color/accent_orange"
                android:paddingVertical="16dp"
                android:text="ACESSAR SISTEMA"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="8dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 3. RODAPÉ (Patrocinadores) -->
    <LinearLayout
        android:id="@+id/layoutFooter"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/footer_bg"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.15"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Logo 1 -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:src="@drawable/ic_placeholder_logo"
            android:contentDescription="Logo Patrocinador 1"
            android:layout_margin="8dp"
            app:tint="@color/text_secondary" />

        <!-- Logo 2 -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:src="@drawable/ic_placeholder_logo"
            android:contentDescription="Logo Patrocinador 2"
            android:layout_margin="8dp"
            app:tint="@color/text_secondary" />

        <!-- Logo 3 -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:src="@drawable/ic_placeholder_logo"
            android:contentDescription="Logo Patrocinador 3"
            android:layout_margin="8dp"
            app:tint="@color/text_secondary" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>