<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    tools:context=".MainActivity">

    <!-- 1. CABEÇALHO (20% da tela ou altura fixa) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:background="#1E1E1E">

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GAME ZONE"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#00FF00"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.1"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4" />
    </LinearLayout>

    <!-- 2. CONTEÚDO PRINCIPAL (60% da tela) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Texto Chamativo -->
        <TextView
            android:id="@+id/tvGamerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DOMINE O JOGO.\nSUPERE SEUS LIMITES."
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textAlignment="center"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="40dp"/>

        <!-- Botão Gamer -->
        <Button
            android:id="@+id/lerQRCodeButton"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="JOGAR AGORA"
            android:textSize="18sp"
            android:textColor="#000000"
            android:backgroundTint="#00FF00"
            android:fontFamily="sans-serif-black"
            android:elevation="10dp"
            android:padding="15dp"/>

    </LinearLayout>

    <!-- 3. RODAPÉ (20% da tela) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:background="#1E1E1E"
        android:orientation="horizontal">

        <!-- Logos dos Patrocinadores -->
        <!-- Substitua 'ic_launcher' pelas suas imagens de logo reais -->
        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_launcher_foreground"
            android:layout_margin="10dp"
            android:contentDescription="Logo 1"/>

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_launcher_foreground"
            android:layout_margin="10dp"
            android:contentDescription="Logo 2"/>

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_launcher_foreground"
            android:layout_margin="10dp"
            android:contentDescription="Logo 3"/>

    </LinearLayout>

</LinearLayout>